# === BaseUFF — configuração (copie para .env; NUNCA versione .env real) ===

# --- Qdrant (host de serving: ultron) ---
UFF_QDRANT_URL=http://localhost:6333
UFF_QDRANT_COLLECTION=uff_chunks

# --- Catálogo (SQLite) ---
UFF_CATALOG_DSN=sqlite:///data/catalog.db

# --- Armazenamento local do acervo ---
UFF_DATA_DIR=data

# --- Crawler (boas práticas) ---
UFF_USER_AGENT=BaseUFF-crawler/0.1 (+contato: contato.papagaionextech@gmail.com)
UFF_REQUESTS_PER_SECOND=1.0
UFF_MAX_CONCURRENCY=4
# Coletar boletins a partir deste ano (inclusive). Definido pelo projeto: 2010 pra cá.
UFF_BOLETIM_START_YEAR=2010

# --- Host de GPU (skynet01, 2x RTX 3060) — NUNCA coloque senha aqui; use chave SSH ---
# Acesso: cid-uff.net:22023 (NAT p/ skynet01, IP interno 10.171.69.10). skynet02 fica livre.
UFF_EMBED_HOST=cid-uff.net
UFF_EMBED_SSH_PORT=22023
UFF_EMBED_SSH_USER=marcus
UFF_EMBED_MODEL=BAAI/bge-m3
# Microserviço no skynet01: /encode + /rerank + /colbert_rerank
UFF_ENCODER_URL=http://10.171.69.10:8010
